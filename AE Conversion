const MIN_OPPS = 3;
let currentSource = 'all';
let currentSort = 'S0S1';

function pctColor(p) {
  if (p === null || p === undefined) return 'transparent';
  if (p === 0) return '#E8624D';
  if (p < 0.15) return '#EE8B6B';
  if (p < 0.25) return '#F2A878';
  if (p < 0.35) return '#F5C488';
  if (p < 0.45) return '#F0D684';
  if (p < 0.55) return '#D6D67E';
  if (p < 0.65) return '#B8CE78';
  if (p < 0.75) return '#9CC273';
  if (p < 0.85) return '#7FB86E';
  return '#5FA85E';
}

function filteredOpps(source) {
  if (source === 'all' || source === 'compare') return OPPS;
  return OPPS.filter(o => o.src === source);
}

function buildSummary(source) {
  const pool = filteredOpps(source);
  const byOwner = {};
  for (const o of pool) {
    if (!byOwner[o.o]) byOwner[o.o] = [];
    byOwner[o.o].push(o);
  }
  const rows = [];
  for (const key of Object.keys(byOwner)) {
    const opps = byOwner[key];
    if (opps.length < MIN_OPPS) continue;
    const s1 = opps.filter(x => x.s1).length;
    const s2 = opps.filter(x => x.s2).length;
    const s3 = opps.filter(x => x.s3).length;
    rows.push({
      owner: key, total: opps.length, s1, s2, s3,
      S0S1: s1 / opps.length,
      S1S2: s1 > 0 ? s2 / s1 : null,
      S2S3: s2 > 0 ? s3 / s2 : null,
    });
  }
  return rows;
}

function buildCompareSummary() {
  // For compare view: include any AE that has >=3 opps in total (even if one source < 3)
  const byOwner = {};
  for (const o of OPPS) {
    if (!byOwner[o.o]) byOwner[o.o] = { BDR: [], AE: [] };
    byOwner[o.o][o.src].push(o);
  }
  const rows = [];
  for (const key of Object.keys(byOwner)) {
    const bdrOpps = byOwner[key].BDR;
    const aeOpps = byOwner[key].AE;
    if (bdrOpps.length + aeOpps.length < MIN_OPPS) continue;

    function calc(opps) {
      if (opps.length === 0) return null;
      const s1 = opps.filter(x => x.s1).length;
      const s2 = opps.filter(x => x.s2).length;
      const s3 = opps.filter(x => x.s3).length;
      return {
        total: opps.length, s1, s2, s3,
        S0S1: s1 / opps.length,
        S1S2: s1 > 0 ? s2 / s1 : null,
        S2S3: s2 > 0 ? s3 / s2 : null,
      };
    }
    rows.push({
      owner: key,
      total: bdrOpps.length + aeOpps.length,
      BDR: calc(bdrOpps),
      AE: calc(aeOpps),
    });
  }
  return rows;
}

let activeCell = null;

function renderPct(owner, stage, value, source) {
  if (value === null || value === undefined) return '<span class="pct empty">&ndash;</span>';
  const color = pctColor(value);
  const display = Math.round(value * 100) + '%';
  return '<span class="pct" data-owner="' + owner + '" data-stage="' + stage + '" data-source="' + source + '" style="background: ' + color + ';">' + display + '</span>';
}

function renderCompareCell(owner, stage, bdr, ae) {
  const bdrPct = bdr ? bdr[stage] : null;
  const aePct = ae ? ae[stage] : null;
  return (
    '<div class="compare-cell">' +
      '<div class="pct-row"><span class="pct-label">BDR</span>' + renderPct(owner, stage, bdrPct, 'BDR') + '</div>' +
      '<div class="pct-row"><span class="pct-label">AE</span>' + renderPct(owner, stage, aePct, 'AE') + '</div>' +
    '</div>'
  );
}

function render() {
  const head = document.getElementById('cvr-head');
  const body = document.getElementById('cvr-body');

  if (currentSource === 'compare') {
    head.innerHTML =
      '<tr>' +
      '<th style="width: 36px;"></th>' +
      '<th class="name-h">AE</th>' +
      '<th style="width: 80px;">Opps</th>' +
      '<th style="width: 110px;">S0 &gt; S1</th>' +
      '<th style="width: 110px;">S1 &gt; S2</th>' +
      '<th style="width: 110px;">S2 &gt; S3</th>' +
      '</tr>';

    const rows = buildCompareSummary();
    rows.sort((a, b) => {
      if (currentSort === 'name') return a.owner.localeCompare(b.owner);
      if (currentSort === 'total') return b.total - a.total;
      // For percentage sort in compare mode: use BDR value (fall back to AE if BDR absent)
      const av = (a.BDR && a.BDR[currentSort] != null) ? a.BDR[currentSort] : (a.AE && a.AE[currentSort] != null ? a.AE[currentSort] : -1);
      const bv = (b.BDR && b.BDR[currentSort] != null) ? b.BDR[currentSort] : (b.AE && b.AE[currentSort] != null ? b.AE[currentSort] : -1);
      return bv - av;
    });

    body.innerHTML = rows.map((r, i) => {
      const bdrCount = r.BDR ? r.BDR.total : 0;
      const aeCount = r.AE ? r.AE.total : 0;
      return '<tr>' +
        '<td class="idx">' + (i + 1) + '</td>' +
        '<td class="name">' + r.owner + '</td>' +
        '<td class="num" style="font-size: 11px;">' +
          '<div>BDR: ' + bdrCount + '</div>' +
          '<div>AE: ' + aeCount + '</div>' +
        '</td>' +
        '<td>' + renderCompareCell(r.owner, 'S0S1', r.BDR, r.AE) + '</td>' +
        '<td>' + renderCompareCell(r.owner, 'S1S2', r.BDR, r.AE) + '</td>' +
        '<td>' + renderCompareCell(r.owner, 'S2S3', r.BDR, r.AE) + '</td>' +
        '</tr>';
    }).join('');
  } else {
    head.innerHTML =
      '<tr>' +
      '<th style="width: 36px;"></th>' +
      '<th class="name-h">AE</th>' +
      '<th style="width: 100px;">Opps (S0)</th>' +
      '<th style="width: 90px;">S0 &gt; S1</th>' +
      '<th style="width: 90px;">S1 &gt; S2</th>' +
      '<th style="width: 90px;">S2 &gt; S3</th>' +
      '</tr>';

    const rows = buildSummary(currentSource);
    rows.sort((a, b) => {
      if (currentSort === 'name') return a.owner.localeCompare(b.owner);
      if (currentSort === 'total') return b.total - a.total;
      const av = a[currentSort] == null ? -1 : a[currentSort];
      const bv = b[currentSort] == null ? -1 : b[currentSort];
      return bv - av;
    });

    body.innerHTML = rows.map((r, i) =>
      '<tr>' +
      '<td class="idx">' + (i + 1) + '</td>' +
      '<td class="name">' + r.owner + '</td>' +
      '<td class="num">' + r.total + '</td>' +
      '<td>' + renderPct(r.owner, 'S0S1', r.S0S1, currentSource) + '</td>' +
      '<td>' + renderPct(r.owner, 'S1S2', r.S1S2, currentSource) + '</td>' +
      '<td>' + renderPct(r.owner, 'S2S3', r.S2S3, currentSource) + '</td>' +
      '</tr>'
    ).join('');
  }

  body.querySelectorAll('.pct:not(.empty)').forEach(el => {
    el.addEventListener('click', () => showDrill(el.dataset.owner, el.dataset.stage, el.dataset.source, el));
  });
}

function fmtARR(v) {
  if (!v) return '\u2014';
  return '\u00a3' + Math.round(v).toLocaleString();
}

function esc(s) { return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

function showDrill(owner, stage, source, cellEl) {
  let opps = OPPS.filter(o => o.o === owner);
  let sourceLabel = 'all sources';
  if (source === 'BDR') { opps = opps.filter(o => o.src === 'BDR'); sourceLabel = 'BDR-sourced'; }
  else if (source === 'AE') { opps = opps.filter(o => o.src === 'AE'); sourceLabel = 'AE-sourced'; }

  let denom, numer, title, denomLabel, numerLabel;
  if (stage === 'S0S1') {
    denom = opps; numer = opps.filter(o => o.s1);
    denomLabel = 'opps taken'; numerLabel = 'reached S1';
    title = esc(owner) + ' &mdash; S0 &gt; S1 (' + sourceLabel + ')';
  } else if (stage === 'S1S2') {
    denom = opps.filter(o => o.s1); numer = opps.filter(o => o.s2);
    denomLabel = 'reached S1'; numerLabel = 'reached S2';
    title = esc(owner) + ' &mdash; S1 &gt; S2 (' + sourceLabel + ')';
  } else {
    denom = opps.filter(o => o.s2); numer = opps.filter(o => o.s3);
    denomLabel = 'reached S2'; numerLabel = 'reached S3';
    title = esc(owner) + ' &mdash; S2 &gt; S3 (' + sourceLabel + ')';
  }

  const rate = denom.length ? Math.round(numer.length / denom.length * 100) : 0;
  const numerSet = new Set(numer.map(o => o.a + '|' + o.m));
  const sorted = [...denom].sort((a, b) => {
    const ac = numerSet.has(a.a + '|' + a.m) ? 0 : 1;
    const bc = numerSet.has(b.a + '|' + b.m) ? 0 : 1;
    if (ac !== bc) return ac - bc;
    return (b.r || 0) - (a.r || 0);
  });

  const rowsHtml = sorted.map(o => {
    const converted = numerSet.has(o.a + '|' + o.m);
    let badge;
    if (converted) badge = '<span class="badge yes">Converted</span>';
    else if (o.s === 'Closed Lost') badge = '<span class="badge no">Closed Lost</span>';
    else badge = '<span class="badge open">Open &middot; ' + esc(o.s) + '</span>';
    const srcPill = '<span class="src-pill ' + o.src.toLowerCase() + '">' + o.src + '</span>';
    return '<tr>' +
      '<td>' + esc(o.a) + '</td>' +
      '<td>' + srcPill + '</td>' +
      '<td>' + esc(o.m || '\u2014') + '</td>' +
      '<td class="r">' + fmtARR(o.r) + '</td>' +
      '<td>' + badge + '</td>' +
      '</tr>';
  }).join('');

  document.getElementById('drill-title').innerHTML = title;
  document.getElementById('drill-meta').textContent = numer.length + ' of ' + denom.length + ' ' + denomLabel + ' ' + numerLabel + ' \u00b7 ' + rate + '%';
  document.getElementById('drill-body').innerHTML =
    '<table class="opps"><thead><tr>' +
    '<th>Account</th><th>Source</th><th>1st meeting</th><th class="r">Forecasted ARR</th><th>Status</th>' +
    '</tr></thead><tbody>' + rowsHtml + '</tbody></table>';
  document.getElementById('drill').classList.remove('hidden');

  if (activeCell) activeCell.classList.remove('active');
  cellEl.classList.add('active');
  activeCell = cellEl;
  document.getElementById('drill').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

document.getElementById('drill-close').addEventListener('click', () => {
  document.getElementById('drill').classList.add('hidden');
  if (activeCell) { activeCell.classList.remove('active'); activeCell = null; }
});

document.getElementById('sort-by').addEventListener('change', (e) => {
  currentSort = e.target.value;
  render();
});

document.querySelectorAll('#source-tabs .tab').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('#source-tabs .tab').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentSource = btn.dataset.source;
    document.getElementById('drill').classList.add('hidden');
    if (activeCell) { activeCell.classList.remove('active'); activeCell = null; }
    render();
  });
});

render();
</script>
</body>
</html>
