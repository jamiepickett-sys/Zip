<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AE Conversion Report</title>
<style>
  :root {
    --bg: #FFFFFF;
    --bg-secondary: #F7F7F5;
    --text-primary: #1A1A1A;
    --text-secondary: #6B7280;
    --text-tertiary: #9AA3AE;
    --border: #E5E7EB;
    --border-light: #F1F2F4;
    --success-bg: #E6F5EC;
    --success-text: #1F6B3D;
    --danger-bg: #FCEBEB;
    --danger-text: #A32D2D;
    --accent: #1A1A1A;
    --radius-md: 8px;
    --radius-lg: 12px;
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
    color: var(--text-primary);
    background: var(--bg);
    margin: 0;
    padding: 32px 24px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }
  h1 { font-size: 24px; font-weight: 600; margin: 0 0 4px; letter-spacing: -0.3px; }
  .sub { font-size: 13px; color: var(--text-secondary); margin: 0; }
  .header-row { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 20px; gap: 16px; flex-wrap: wrap; }
  .controls { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .control-group { display: flex; gap: 8px; align-items: center; font-size: 12px; color: var(--text-secondary); }
  .control-group select { font-size: 12px; padding: 6px 10px; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text-primary); cursor: pointer; }
  .tabs { display: inline-flex; background: var(--bg-secondary); padding: 3px; border-radius: 8px; gap: 2px; }
  .tab { font-size: 12px; padding: 6px 14px; border: none; background: transparent; border-radius: 6px; cursor: pointer; color: var(--text-secondary); font-weight: 500; transition: all 0.12s; }
  .tab:hover { color: var(--text-primary); }
  .tab.active { background: var(--bg); color: var(--text-primary); box-shadow: 0 1px 2px rgba(0,0,0,0.06); }
  table.cvr { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; }
  table.cvr th { text-align: center; font-weight: 500; font-size: 11.5px; color: var(--text-secondary); padding: 10px 6px; border-bottom: 1px solid var(--border); }
  table.cvr th.name-h { text-align: left; }
  table.cvr td { text-align: center; padding: 10px 6px; border-bottom: 1px solid var(--border-light); vertical-align: middle; }
  table.cvr td.idx { color: var(--text-tertiary); font-size: 11px; width: 36px; }
  table.cvr td.name { text-align: left; font-weight: 500; }
  table.cvr td.num { color: var(--text-secondary); font-variant-numeric: tabular-nums; }
  .pct { display: inline-block; width: 56px; padding: 5px 0; border-radius: var(--radius-md); color: #fff; font-weight: 500; font-variant-numeric: tabular-nums; cursor: pointer; transition: transform 0.08s; font-size: 12px; }
  .pct:hover { transform: scale(1.06); }
  .pct.empty { background: transparent; color: var(--text-tertiary); cursor: default; }
  .pct.empty:hover { transform: none; }
  .pct.active { outline: 2px solid var(--accent); outline-offset: 2px; }
  .compare-cell { display: flex; flex-direction: column; gap: 3px; align-items: center; }
  .pct-row { display: flex; gap: 4px; align-items: center; justify-content: center; }
  .pct-label { font-size: 9px; color: var(--text-tertiary); font-weight: 500; letter-spacing: 0.3px; width: 18px; text-align: right; }
  .drill { margin-top: 1.5rem; background: var(--bg-secondary); border-radius: var(--radius-lg); padding: 16px 20px; }
  .drill.hidden { display: none; }
  .drill-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
  .drill-title { font-size: 15px; font-weight: 600; margin: 0; }
  .drill-meta { font-size: 12px; color: var(--text-secondary); margin: 2px 0 0; }
  .drill-close { font-size: 12px; cursor: pointer; color: var(--text-secondary); background: none; border: none; padding: 6px 10px; border-radius: 6px; }
  .drill-close:hover { background: rgba(0,0,0,0.05); color: var(--text-primary); }
  table.opps { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 12px; background: var(--bg); border-radius: var(--radius-md); overflow: hidden; }
  table.opps th { text-align: left; font-weight: 500; color: var(--text-secondary); padding: 8px 10px; font-size: 11px; border-bottom: 1px solid var(--border); }
  table.opps th.r, table.opps td.r { text-align: right; }
  table.opps td { padding: 8px 10px; border-bottom: 1px solid var(--border-light); }
  table.opps tr:last-child td { border-bottom: none; }
  .src-pill { display: inline-block; padding: 1px 6px; border-radius: 8px; font-size: 10px; font-weight: 500; }
  .src-pill.bdr { background: #E6F1FB; color: #0C447C; }
  .src-pill.ae { background: #F0EDFE; color: #3C3489; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 10.5px; font-weight: 500; white-space: nowrap; }
  .badge.yes { background: var(--success-bg); color: var(--success-text); }
  .badge.no { background: var(--danger-bg); color: var(--danger-text); }
  .badge.open { background: var(--bg); color: var(--text-secondary); border: 1px solid var(--border); }
  .legend { display: flex; gap: 16px; font-size: 11px; color: var(--text-secondary); align-items: center; margin-top: 14px; flex-wrap: wrap; }
  .legend-item { display: flex; gap: 6px; align-items: center; }
  .legend-swatch { width: 16px; height: 10px; border-radius: 3px; }
  .footnote { margin-top: 24px; font-size: 11px; color: var(--text-tertiary); }
</style>
</head>
